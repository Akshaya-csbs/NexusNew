rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Phase 4: Entity Blueprints
    function isValidCrisis(data) {
      return data.crisisType in ['fire', 'smoke', 'intrusion', 'panic']
          && data.floor is int
          && data.roomNumber is string
          && data.roomNumber.size() <= 64
          && data.severity in ['low', 'medium', 'high', 'critical']
          && data.status in ['active', 'contained', 'resolved'];
    }

    function isValidRoom(data) {
      return data.roomNumber is string
          && data.roomNumber.size() <= 64
          && data.floor is int
          && data.occupancyStatus in ['evacuated', 'occupied', 'unknown'];
    }

    function isValidLog(data) {
      return data.event is string && data.event.size() <= 1000
          && data.source is string
          && data.status is string
          && data.category is string;
    }

    // --- Collection Routes ---

    match /crises/{crisisId} {
      allow read: if true; // Public safety broadcasts
      allow create: if isValidCrisis(incoming()) && (incoming().timestamp == request.time);
      allow update: if isValidCrisis(incoming());
      allow delete: if true; // Managed by cleanup routine
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isValidRoom(incoming());
    }

    match /units/{unitId} {
      allow read: if true;
      allow write: if true; // Demo allows unit state updates
    }

    match /logs/{logId} {
      allow read: if true;
      allow create: if isValidLog(incoming());
      allow delete: if true;
    }
  }
}
